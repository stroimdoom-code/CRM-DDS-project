# Django settings
SECRET_KEY=ваш-секретный-ключ-сгенерируйте-командой-below
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite для разработки, PostgreSQL для production)
# Для SQLite (разработка) - оставьте пустым или раскомментируйте:
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Для PostgreSQL (production) - раскомментируйте и заполните:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=crm_dds_db
# DB_USER=postgres
# DB_PASSWORD=ваш-пароль
# DB_HOST=localhost
# DB_PORT=5432

# Сгенерировать SECRET_KEY:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"